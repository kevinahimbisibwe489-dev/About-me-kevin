* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: 'Arial', sans-serif;
  background: #0f172a;
  color: #e2e8f0;
  line-height: 1.6;
}
header {
  background: #1e293b;
  padding: 20px;
  text-align: center;
}
header h1 { color: #00D9FF; font-size: 2em; }
nav a {
  color: #e2e8f0;
  margin: 0 15px;
  text-decoration: none;
  font-weight: bold;
}
nav a:hover { color: #00D9FF; }
section {
  padding: 50px 20px;
  max-width: 900px;
  margin: auto;
  text-align: center;
}
.hero h2 { font-size: 2.5em; color: #00D9FF; margin-top: 20px; }
.btn {
  display: inline-block;
  background: #00D9FF;
  color: #0f172a;
  padding: 12px 25px;
  border-radius: 8px;
  text-decoration: none;
  margin-top: 20px;
  font-weight: bold;
}
.btn:hover { background: #00B8D9; }
footer {
  background: #1e293b;
  text-align: center;
  padding: 20px;
  margin-top: 40px;
}
